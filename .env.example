# ============================================================
# NEXUS GESTÃO — Variáveis de Ambiente
# Copie e cole cada linha abaixo no painel Environment Variables
# do Coolify. Após o primeiro deploy funcionando, substitua os
# tokens JWT por novos valores: openssl rand -base64 64
# ============================================================

# ── BANCO DE DADOS (PostgreSQL 17 nativo na VPS) ─────────────
DATABASE_URL=postgres://usuario:senha@postgres:5432/postgres
# Defina como 'true' se o banco exigir SSL/TLS (ex: Supabase, Neon, RDS)
DATABASE_SSL=false

# ── AUTENTICAÇÃO JWT (tokens gerados com openssl rand -base64 64) ─
JWT_SECRET=gere-com-openssl-rand-base64-64
JWT_REFRESH_SECRET=gere-outra-chave-com-openssl-rand-base64-64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── DOMÍNIO E FRONTEND ───────────────────────────────────────
FRONTEND_URL=https://nexus.permupay.com.br
DOMAIN=nexus.permupay.com.br

# ── SERVIDOR ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_PORT=3002

# ── UPLOADS ──────────────────────────────────────────────────
MAX_FILE_SIZE=52428800
UPLOADS_DIR=/app/uploads

# ── VITE (Frontend — Build Time) ─────────────────────────────
VITE_API_URL=/api

# ============================================================
# NOTA: O arquivo .env real NÃO deve ser commitado no Git.
# Configure as variáveis diretamente no painel do Coolify.

# Domínio do Destrava autorizado a abrir o Nexus dentro de iframe e chamar a ponte.
DESTRAVA_FRONTEND_URL=https://destravacredito.com
# Origens extras separadas por vírgula, se houver outros domínios do Destrava.
CORS_EXTRA_ORIGINS=https://destravacredito.com.br
# Controle de quem pode incorporar o Nexus em iframe.
NEXUS_ALLOWED_FRAME_ANCESTORS='self' https://destravacredito.com https://destravacredito.com.br

# ── INTEGRAÇÃO DESTRAVA ↔ NEXUS ─────────────────────────────
# Use a mesma chave no Destrava: NEXUS_INTEGRATION_SECRET
NEXUS_DESTRAVA_INTEGRATION_SECRET=gere-uma-chave-forte
# Opcional: limita a organização/usuário padrão usado pela integração.
NEXUS_DESTRAVA_ORG_ID=
NEXUS_DESTRAVA_DEFAULT_USER_EMAIL=
NEXUS_DESTRAVA_DEFAULT_USER_ID=

# ============================================================

# Integração Nexus ↔ Destrava
DESTRAVA_API_URL=https://destravacredito.com

# Inteligência operacional com Gemini (opcional)
# O sistema funciona sem esta chave usando análise local do PostgreSQL.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ── SINCRONIZAÇÃO AUTOMÁTICA COM AGENDA / GOOGLE CALENDAR ─────
# A agenda interna do Nexus será sincronizada automaticamente com tarefas,
# contas a pagar, contas a receber e compromissos.
AGENDA_AUTO_SYNC_ENABLED=true
AGENDA_AUTO_SYNC_INTERVAL_MINUTES=10
# Opcional: para também enviar os eventos ao Google Agenda, configure uma service account.
# Compartilhe o calendário desejado com o e-mail client_email da service account.
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo
# Use APENAS uma das opções abaixo:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=

# ── BACKUP AUTOMÁTICO LOCAL + GOOGLE DRIVE ─────────────────────
BACKUP_AUTO_ENABLED=true
BACKUP_AUTO_HOUR=3
BACKUP_AUTO_MINUTE=15
BACKUP_LOCAL_DIR=/app/backups
BACKUP_LOCAL_KEEP_LAST=14
# Para enviar backup ao Drive, compartilhe a pasta com o client_email da service account
# e informe o ID da pasta abaixo.
GOOGLE_DRIVE_FOLDER_ID=

# Web Push / Push Notifications
# Gere com: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@nexus.local

# Sessão persistente: o usuário não desloga sozinho enquanto o refresh token estiver válido.
JWT_REFRESH_EXPIRES_IN=365d

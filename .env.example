# ============================================================
# NEXUS — Variáveis de Ambiente
# ============================================================
# PASSO A PASSO:
# 1. Copie este arquivo e renomeie para: .env
# 2. Acesse https://supabase.com → seu projeto → Settings → API
# 3. Copie "Project URL" e cole em VITE_SUPABASE_URL
# 4. Copie "anon public" key e cole em VITE_SUPABASE_ANON_KEY
# 5. Execute o arquivo supabase-schema.sql no SQL Editor do Supabase
# 6. Rode: npm run dev
# ============================================================

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SUA_CHAVE_AQUI

# NOTA: Este arquivo (.env) deve ser listado no .gitignore.

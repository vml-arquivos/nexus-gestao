# ============================================================
# NEXUS GESTÃO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# No Coolify: configure cada variável no painel Environment Variables
# ============================================================

# ── BANCO DE DADOS (PostgreSQL 17 nativo na VPS) ─────────────
# Formato: postgres://usuario:senha@host:porta/banco
DATABASE_URL=postgres://postgres:SUA_SENHA@SEU_HOST:5432/postgres

# ── AUTENTICAÇÃO JWT ─────────────────────────────────────────
# IMPORTANTE: Gere valores aleatórios seguros para produção!
# Use: openssl rand -base64 64
JWT_SECRET=TROQUE_POR_VALOR_ALEATORIO_SEGURO_64_CHARS
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_VALOR_ALEATORIO_SEGURO_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── DOMÍNIO E FRONTEND ───────────────────────────────────────
FRONTEND_URL=https://nexus.permupay.com.br
DOMAIN=nexus.permupay.com.br

# ── SERVIDOR ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_PORT=3000

# ── UPLOADS ──────────────────────────────────────────────────
# Tamanho máximo de arquivo em bytes (padrão: 50MB)
MAX_FILE_SIZE=52428800
UPLOADS_DIR=/app/uploads

# ── VITE (Frontend — Build Time) ─────────────────────────────
# Aponta para /api (proxy nginx → backend)
VITE_API_URL=/api

# ============================================================
# NOTA: O arquivo .env real NÃO deve ser commitado no Git.
# Configure as variáveis diretamente no painel do Coolify.
# ============================================================
